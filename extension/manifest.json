{
  "manifest_version": 3,
  "name": "LinkedIn Prospector — Cromosit IT",
  "version": "3.1.0",
  "description": "Capture leads do LinkedIn em 1 clique — individual ou em massa",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://linkedin-prospector-production.up.railway.app/*",
    "https://prospector.cromosit.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://prospector.cromosit.com/*"],
      "js": ["app_bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
