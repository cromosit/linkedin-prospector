{
  "manifest_version": 3,
  "name": "LinkedIn Prospector — Cromosit IT",
  "version": "4.3.0",
  "description": "Capture leads do LinkedIn em 1 clique",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://prospector.cromosit.com/*",
    "http://localhost:3000/*",
    "http://localhost:3001/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*.linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:5174/*",
        "http://localhost:5174/*",
        "https://prospector.cromosit.com/*"
      ],
      "js": ["app_bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
