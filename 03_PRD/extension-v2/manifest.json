{
  "manifest_version": 3,
  "name": "LinkedIn Prospector v3.0.0 ULTRA [CROMOSIT ELITE-PATH]",
  "version": "3.0.0",
  "description": "Cérebro Híbrido: Captura de Nome Real + Envio Resiliente Frederico Fix.",
  "permissions": ["activeTab", "storage", "scripting", "tabs"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://linkedin-prospector-production.up.railway.app/*",
    "https://prospector.cromosit.com/*"
  ],
  "externally_connectable": {
    "matches": [
      "https://prospector.cromosit.com/*",
      "https://linkedin-prospector-production.up.railway.app/*"
    ]
  },
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html" },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["sync-engine.js", "content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
