# ==========================================
# LINKEDIN (pegar no LinkedIn Developer Portal)
# ==========================================
LINKEDIN_CLIENT_ID=cole_aqui_o_client_id
LINKEDIN_CLIENT_SECRET=cole_aqui_o_client_secret
LINKEDIN_REDIRECT_URI=http://localhost:3000/auth/linkedin/callback

# ==========================================
# JWT (chave secreta — coloque qualquer texto longo e aleatório)
# Exemplo: uma frase longa como "minha-chave-super-secreta-2024-cromosit"
# ==========================================
JWT_SECRET=coloque-uma-frase-longa-e-aleatoria-aqui

# ==========================================
# SUPABASE (pegar no painel do Supabase > Settings > API)
# Use a chave "service_role" — NÃO use a "anon"!
# ==========================================
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=cole_aqui_a_chave_service_role_do_supabase

# ==========================================
# OPENAI (pegar em platform.openai.com > API Keys)
# ==========================================
OPENAI_API_KEY=sk-proj-cole_aqui_a_chave_da_openai

# ==========================================
# CHATWA — Envio de WhatsApp (Cromosit IT)
# ==========================================
CHATWA_API_URL=https://apichatwa.cromosit.com/api/messages
CHATWA_TOKEN=cole_aqui_o_token_da_instancia_chatwa

# ==========================================
# NOTIFICAÇÕES — Número do vendedor para receber alertas
# Formato: código do país + DDD + número (sem espaços ou traços)
# Exemplo: 5541991719998
# ==========================================
VENDEDOR_WHATSAPP=5541XXXXXXXXX

# ==========================================
# CONFIGURAÇÕES DO SERVIDOR
# ==========================================
PORT=3000
FRONTEND_URL=http://localhost:5173

# ==========================================
# AMBIENTE (development ou production)
# ==========================================
NODE_ENV=development
